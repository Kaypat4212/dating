<IfModule mod_rewrite.c>
    Options -Indexes +FollowSymLinks
    RewriteEngine On

    # If the URI maps to a real file inside public/ (assets, images, build, storage…)
    # serve it directly — this covers /build/*, /storage/*, /css/*, /js/*, /fonts/* etc.
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # Anything else — including the bare root / — goes to Laravel's front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>
