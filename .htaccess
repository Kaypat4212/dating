# Serve index.php by default for any directory request
DirectoryIndex index.php

# ── cPanel / shared-hosting SSL proxy detection ─────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:X-Https} 1
    RewriteRule .* - [E=HTTPS:on]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Static assets that physically live inside public/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # Let real root-level files pass through
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else goes to the root index.php
    RewriteRule ^ index.php [L,QSA]
</IfModule>
