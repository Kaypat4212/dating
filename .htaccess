# Serve index.php by default for any directory request
DirectoryIndex index.php

# ── cPanel / shared-hosting SSL proxy detection ─────────────────────────────
# cPanel terminates SSL and passes x-https:1 instead of X-Forwarded-Proto.
# This sets HTTPS=on so PHP / Laravel URL generator uses https:// for assets.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:X-Https} 1
    RewriteRule .* - [E=HTTPS:on]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Static assets that physically live inside public/ (build, storage, css, fonts…)
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # Let real root-level files pass through as-is (robots.txt, sw.js, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else goes to the root index.php front controller
    RewriteRule ^ index.php [L,QSA]
</IfModule>
